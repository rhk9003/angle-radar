# 複製本檔為 secrets.toml 後填入實際值。
# secrets.toml 已被 .gitignore 排除，不會進 public repo。
# 部署到 Streamlit Community Cloud 時，改在網站的 Secrets 介面貼同樣內容。

GEMINI_API_KEY = "你的 Gemini API key"
YOUTUBE_API_KEY = "你的 YouTube Data API key"

# ── 白名單（剩餘次數倒扣模型）──
# 由綁在白名單 Google Sheet 上的 Apps Script Web App 負責讀寫（Sheet 私有、免服務帳號）。
# Sheet 必要欄位：code | name | remaining
#   remaining=剩餘次數（每成功產出報告扣 1，0 就不能用；加值＝改大數字）
#   舊表的 deep_mode 欄位可以保留，新版一般模式不會使用它
# 兩行都沒設 = 白名單關閉（本機自用直接進）。GAS 程式與設定見 whitelist_gas/SETUP.md
WHITELIST_API_URL = "GAS Web App 部署後的 /exec 網址"
WHITELIST_API_KEY = "自己編一串密鑰，需與 GAS Code 內的 API_KEY 一致"

# 管理者碼（選填）：用這組 code 登入才看得到「模型設定」與「進階設定」，
# 其他試用者一律用固定預設值（控成本、介面乾淨）。此碼也要是白名單裡的一列。
ADMIN_CODE = "你的管理者試用碼，例如 dennis1234"

# 僅供沒有白名單的本機開發。公開部署請維持 false，避免顯示內部診斷。
SHOW_ADMIN_DIAGNOSTICS = false
