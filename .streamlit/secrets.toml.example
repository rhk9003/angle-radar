# 複製本檔為 secrets.toml 後填入實際值。
# secrets.toml 已被 .gitignore 排除，不會進 public repo。
# 部署到 Streamlit Community Cloud 時，改在網站的 Secrets 介面貼同樣內容。

GEMINI_API_KEY = "你的 Gemini API key"
YOUTUBE_API_KEY = "你的 YouTube Data API key"

# ── 白名單 Google Sheet ──
# 分頁第一列表頭需為：code | name | active | daily_limit | deep_mode
#   code=試用碼  name=暱稱  active=FALSE停用(空白啟用)
#   daily_limit=每日次數上限(空白或0=不限)  deep_mode=FALSE關閉深度拆解(空白=允許)
WHITELIST_SHEET_ID = "Google Sheet 網址 /d/ 與 /edit 之間那段 ID"
WHITELIST_SHEET_GID = "0"   # 填 "0" 或留空＝用第一個分頁（最穩，建議）；只有白名單不在第一頁時才填實際 gid

# ── 服務帳號（選填，設了才是 FULL 模式：能真的記錄用量、限次生效）──
# 沒設這段 = LITE 模式（唯讀白名單，功能開關可用，限次只在單一 session 內軟性計數）。
# 設定方式見 README「限次（FULL 模式）」。JSON 金鑰內容整段貼進來：
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "xxx@xxx.iam.gserviceaccount.com"
# client_id = "..."
# token_uri = "https://oauth2.googleapis.com/token"
